<?xml version="1.0" encoding="utf-8"?>
<!--
  Cola Music launcher foreground — a cute kitty face.
  viewport 108x108 dp; adaptive-icon safe zone is roughly (21,21)→(87,87).
  Render order matters: background ears → face → facial features → whiskers.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer ears (white triangles peeking out of the head) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M30,36 L24,22 L46,30 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M78,36 L84,22 L62,30 Z" />

    <!-- Inner ears (pink) -->
    <path
        android:fillColor="#FFB3BF"
        android:pathData="M32,33 L28,25 L41,30 Z" />
    <path
        android:fillColor="#FFB3BF"
        android:pathData="M76,33 L80,25 L67,30 Z" />

